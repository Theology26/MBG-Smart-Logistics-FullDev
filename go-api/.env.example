# ============================================================================
# MBG Smart Logistics — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================================

# ── PostgreSQL ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_USER=mbg_admin
DB_PASSWORD=admin
DB_NAME=mbg_smart_logistics

# ── OSRM (Local Docker) ────────────────────────────────────────────────
OSRM_BASE_URL=http://localhost:5000

# ── Gemini AI ───────────────────────────────────────────────────────────
# Get your key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_google_ai_studio_api_key_here"
GEMINI_MODEL=gemini-2.0-flash

# ── Server ──────────────────────────────────────────────────────────────
SERVER_PORT=8080
JWT_SECRET=mbg-smart-logistics-jwt-secret-change-in-production

# ── Redis ───────────────────────────────────────────────────────────────
REDIS_URL=localhost:6379

# ── Shelf-Life Config ──────────────────────────────────────────────────
# Buffer time subtracted from shelf-life for delivery window (minutes)
SHELF_LIFE_BUFFER_MINUTES=30

# ── CVRPTW Solver ──────────────────────────────────────────────────────
# Default service time at each school stop (seconds)
DEFAULT_SERVICE_TIME_SECONDS=300
# Maximum iterations for 2-opt improvement
MAX_IMPROVEMENT_ITERATIONS=1000
